{
  "expo": {
    "name": "Fata Morgana",
    "slug": "fata-morgana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0E0A07"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fatamorgana.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "package": "com.fatamorgana.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "fatamorgana",
    "newArchEnabled": true
  }
}
